# .env.example
# Copy to .env and fill in values before running inference.py

# ── LLM (inference.py) ──────────────────────────────
OPENAI_API_KEY=sk-...
API_BASE_URL=https://api.openai.com/v1   # or https://api.together.xyz/v1 etc.
MODEL_NAME=gpt-4o-mini

# ── Server ───────────────────────────────────────────
ENV_BASE_URL=http://localhost:8000

# ── HF Spaces (set by platform, don't need locally) ──
# ENABLE_WEB_INTERFACE=true
